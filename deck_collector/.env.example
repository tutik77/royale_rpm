# PostgreSQL
DATABASE_URL=postgresql://deck_collector:deck_collector@db:5432/deck_collector

# Redis (Celery broker & backend)
REDIS_URL=redis://redis:6379/0

# Clash Royale API
# Get your token at https://developer.clashroyale.com/
# IMPORTANT: token is IP-whitelisted. If running in Docker, your outgoing IP
# must match the one registered for the token.
# Alternative: use proxy.royaleapi.dev (same auth, no IP restriction):
#   CLASH_API_BASE_URL=https://proxy.royaleapi.dev/v1
CLASH_API_BASE_URL=https://api.clashroyale.com/v1
CLASH_API_TOKEN=your_token_here

# Collection settings
COLLECTION_INTERVAL_SECONDS=14400
TOP_PLAYERS_LIMIT=200
LOCATION_ID=global
REQUEST_DELAY=0.05
